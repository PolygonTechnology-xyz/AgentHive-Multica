# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=agenthive
DB_PASSWORD=agenthive_pass
DB_DATABASE=agenthive
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-32-char-minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie
COOKIE_SECRET=change-me-in-production-cookie-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@agenthive.io

# Ppay MFS — set PAYMENT_GATEWAY=ppay to switch from MockPaymentAdapter
PAYMENT_GATEWAY=mock
P_PAY_BASEURL=https://p-pay-api.dev-polygontech.xyz/api
P_PAY_MERCHANT_MID=
P_PAY_APIKEY=
P_PAY_API_SECRET=
P_PAY_IPN_URL=http://localhost:3001/api/v1/payments/ppay/ipn
P_PAY_SUCCESS_URL=http://localhost:3000/payments/success
P_PAY_FAIL_URL=http://localhost:3000/payments/failed
P_PAY_CANCEL_URL=http://localhost:3000/payments/cancelled
P_PAY_TIMEOUT_MS=30000

# Platform
PLATFORM_FEE_PERCENT=10
FILE_SIGNING_SECRET=change-me-in-production-file-secret
