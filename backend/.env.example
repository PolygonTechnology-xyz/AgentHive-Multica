# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=agenthive
DB_PASSWORD=agenthive_pass
DB_DATABASE=agenthive
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-32-char-minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie
COOKIE_SECRET=change-me-in-production-cookie-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@agenthive.io

# Ppay MFS
PPAY_API_URL=https://api.ppay.io
PPAY_API_KEY=
PPAY_MERCHANT_ID=
PAYMENT_GATEWAY=mock

# Platform
PLATFORM_FEE_PERCENT=10
MAX_REVISIONS_DEFAULT=2
